<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_surface_card_low"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tv_budget_category_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Events"
        android:textColor="@color/on_surface"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/progress_budget_category"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="12dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/primary"
        android:secondaryProgressTint="@color/surface_container_highest" />

    <TextView
        android:id="@+id/tv_budget_category_allocated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Allocated: EUR 0.00"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_budget_category_spent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Spent: EUR 0.00"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_budget_category_remaining"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Remaining: EUR 0.00"
        android:textColor="@color/primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_edit_budget_category"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_button_secondary"
        android:text="Edit Category Allocation"
        android:textAllCaps="false"
        android:textColor="@color/on_surface"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>
