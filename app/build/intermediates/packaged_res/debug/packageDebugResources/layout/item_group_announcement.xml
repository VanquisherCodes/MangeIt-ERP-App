<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_surface_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tv_group_announcement_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Announcement title"
        android:textColor="@color/on_surface"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_group_announcement_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Announcement message"
        android:textColor="@color/on_surface_variant"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_group_announcement_published_at"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Published: 2026-05-01 10:00:00"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_edit_group_announcement"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Edit"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_delete_group_announcement"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
