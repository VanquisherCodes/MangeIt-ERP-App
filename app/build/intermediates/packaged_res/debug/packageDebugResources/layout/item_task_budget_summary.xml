<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_surface_card_low"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tv_task_budget_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome Event"
        android:textColor="@color/on_surface"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_task_budget_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="events • Priority HIGH"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_task_budget_allocated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Allocated: EUR 0.00"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_task_budget_predicted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Predicted: EUR 0.00"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_task_budget_actual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Actual: EUR 0.00"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_task_budget_variance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Variance: On budget"
        android:textColor="@color/tertiary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_edit_task_budget_allocation"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Edit Allocation"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_update_task_budget_actual"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Update Actual"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_add_task_budget_expense"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Add Expense"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_view_task_budget_expenses"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="View Expenses"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
