<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_surface_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_group_event_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Event title"
        android:textColor="@color/on_surface"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_group_event_datetime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="When: 2026-05-05 14:00"
        android:textColor="@color/tertiary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_group_event_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Event description"
        android:textColor="@color/on_surface_variant"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_edit_group_event"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Edit"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_delete_group_event"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
