<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/bg_top_bar"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_avatar_dark">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="E"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:text="ManageIt"
                android:textColor="@color/primary"
                android:textSize="22sp" />

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Search"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="@color/on_surface" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="98dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Event Dashboard"
                    android:textColor="@color/on_surface"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Tracking group engagement and upcoming milestones."
                    android:textColor="#C5CCD4"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.12"
                        android:text="AVERAGE PARTICIPATION"
                        android:textColor="@color/primary"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="87.4%"
                            android:textColor="@color/on_surface"
                            android:textSize="34sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="↑ 12%"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp"
                        android:max="100"
                        android:progress="87"
                        android:progressBackgroundTint="#253047"
                        android:progressTint="@color/primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-black"
                            android:text="Calendar\nView"
                            android:textColor="@color/on_surface"
                            android:textSize="18sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_media_previous"
                            android:tint="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:text="October\n2023"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_media_next"
                            android:tint="@color/on_surface" />
                    </LinearLayout>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:columnCount="7"
                        android:rowCount="6">

                        <TextView android:text="MON" android:textColor="#AFB6C2" android:textSize="10sp" />
                        <TextView android:text="TUE" android:textColor="#AFB6C2" android:textSize="10sp" />
                        <TextView android:text="WED" android:textColor="#AFB6C2" android:textSize="10sp" />
                        <TextView android:text="THU" android:textColor="#AFB6C2" android:textSize="10sp" />
                        <TextView android:text="FRI" android:textColor="#AFB6C2" android:textSize="10sp" />
                        <TextView android:text="SAT" android:textColor="#AFB6C2" android:textSize="10sp" />
                        <TextView android:text="SUN" android:textColor="#AFB6C2" android:textSize="10sp" />

                        <TextView android:text="25" android:textColor="#596174" android:paddingTop="14dp" />
                        <TextView android:text="26" android:textColor="#596174" android:paddingTop="14dp" />
                        <TextView android:text="27" android:textColor="#596174" android:paddingTop="14dp" />
                        <TextView android:text="28" android:textColor="#596174" android:paddingTop="14dp" />
                        <TextView android:text="29" android:textColor="#596174" android:paddingTop="14dp" />
                        <TextView android:text="30" android:textColor="#596174" android:paddingTop="14dp" />
                        <TextView
                            android:background="@drawable/bg_calendar_selected"
                            android:gravity="center"
                            android:padding="12dp"
                            android:text="1"
                            android:textColor="@color/on_surface" />

                        <TextView android:text="2" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="3" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="4" android:textColor="@color/primary" android:paddingTop="18dp" />
                        <TextView android:text="5" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="6" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="7" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="8" android:textColor="@color/on_surface" android:paddingTop="18dp" />

                        <TextView android:text="9" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="10" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="11" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="12" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="13" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="14" android:textColor="@color/on_surface" android:paddingTop="18dp" />
                        <TextView android:text="" android:paddingTop="18dp" />
                    </GridLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-black"
                        android:text="Upcoming"
                        android:textColor="@color/on_surface"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_surface_card_high"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:text="11 OCT"
                        android:textColor="@color/on_surface"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Leadership Summit"
                        android:textColor="@color/on_surface"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Quarterly strategic alignment for core team members and leads."
                        android:textColor="#B5BCC8"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <Button
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button_primary"
                            android:text="RSVP YES"
                            android:textAllCaps="false"
                            android:textColor="@color/on_primary"
                            android:textStyle="bold" />

                        <ImageButton
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_button_secondary"
                            android:contentDescription="View"
                            android:padding="12dp"
                            android:src="@android:drawable/ic_menu_view"
                            android:tint="@color/on_surface" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/tertiary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_surface_card_high"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="06 OCT"
                            android:textColor="@color/on_surface"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:fontFamily="sans-serif-black"
                            android:text="Bio Workshop"
                            android:textColor="@color/on_surface"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Hands-on session with the new lab equipment and safety protocols."
                            android:textColor="#B5BCC8"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <Button
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_button_primary"
                                android:text="RSVP YES"
                                android:textAllCaps="false"
                                android:textColor="@color/on_primary"
                                android:textStyle="bold" />

                            <ImageButton
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginStart="10dp"
                                android:background="@drawable/bg_button_secondary"
                                android:contentDescription="View"
                                android:padding="12dp"
                                android:src="@android:drawable/ic_menu_view"
                                android:tint="@color/on_surface" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_surface_card_high"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:text="18 OCT"
                        android:textColor="@color/on_surface"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Dev Sync"
                        android:textColor="@color/on_surface"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="ATTENDING"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Button
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_button_secondary"
                        android:text="Change RSVP"
                        android:textAllCaps="false"
                        android:textColor="@color/on_surface"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_surface_card_high"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Need to host a session?"
                        android:textColor="@color/on_surface"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Administrators can initialize new group sessions using the createEvent() method. Define parameters, set budgets, and invite members instantly."
                        android:textColor="#D1D6DA"
                        android:textSize="16sp" />

                    <Button
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_button_primary"
                        android:text="CREATE NEW EVENT"
                        android:textAllCaps="false"
                        android:textColor="@color/on_primary"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:background="@drawable/bg_bottom_nav"
            android:elevation="12dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_view" android:tint="#9AA3B2" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textColor="#9AA3B2" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_myplaces" android:tint="#9AA3B2" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MEMBERS" android:textColor="#9AA3B2" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_nav_item_active" android:gravity="center" android:orientation="vertical" android:paddingVertical="8dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_my_calendar" android:tint="@color/primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EVENTS" android:textColor="@color/primary" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/checkbox_on_background" android:tint="#9AA3B2" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TASKS" android:textColor="#9AA3B2" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_manage" android:tint="#9AA3B2" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FINANCE" android:textColor="#9AA3B2" android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="70dp"
        android:background="@drawable/bg_fab_primary"
        android:contentDescription="Add"
        android:elevation="12dp"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_add"
        android:tint="@color/on_primary" />
</FrameLayout>
