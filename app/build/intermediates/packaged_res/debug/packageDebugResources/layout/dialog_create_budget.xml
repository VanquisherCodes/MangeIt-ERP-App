<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp">

    <EditText
        android:id="@+id/et_budget_name"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_input_field"
        android:hint="Budget name"
        android:paddingHorizontal="18dp"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_variant" />

    <EditText
        android:id="@+id/et_budget_description"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:gravity="top|start"
        android:hint="Description (optional)"
        android:padding="18dp"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_variant" />

    <EditText
        android:id="@+id/et_budget_total_amount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:hint="Total amount (e.g. 5000.00)"
        android:inputType="numberDecimal"
        android:paddingHorizontal="18dp"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_variant" />

    <EditText
        android:id="@+id/et_budget_period_start"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:hint="Period start (YYYY-MM-DD)"
        android:paddingHorizontal="18dp"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_variant" />

    <EditText
        android:id="@+id/et_budget_period_end"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:hint="Period end (YYYY-MM-DD)"
        android:paddingHorizontal="18dp"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_variant" />
</LinearLayout>
