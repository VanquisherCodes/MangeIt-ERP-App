<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp">

    <Spinner
        android:id="@+id/spinner_allocate_task"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_input_field"
        android:paddingHorizontal="12dp" />

    <Spinner
        android:id="@+id/spinner_allocate_category"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:paddingHorizontal="12dp" />

    <EditText
        android:id="@+id/et_allocate_amount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:hint="Allocation amount"
        android:inputType="numberDecimal"
        android:paddingHorizontal="18dp"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_variant" />

    <Button
        android:id="@+id/btn_allocate_predict_cost"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_secondary"
        android:text="Predict Cost"
        android:textAllCaps="false"
        android:textColor="@color/on_surface"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_allocate_prediction_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_allocate_prediction_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
