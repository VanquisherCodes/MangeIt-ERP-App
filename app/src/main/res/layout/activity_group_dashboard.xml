<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_group_dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_bar"
        android:elevation="0dp"
        android:paddingHorizontal="4dp"
        android:theme="@style/ThemeOverlay.MaterialComponents.ActionBar"
        app:title="Group Dashboard"
        app:titleTextColor="@color/on_surface" />

    <FrameLayout
        android:id="@+id/fragment_container_group_dashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/surface" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_bar"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="18dp">

        <Button
            android:id="@+id/btn_back_to_groups"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_secondary"
            android:paddingHorizontal="18dp"
            android:text="Back To Groups"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
