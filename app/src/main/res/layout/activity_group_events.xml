<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_group_events"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_bar"
        android:elevation="0dp"
        android:paddingHorizontal="4dp"
        android:theme="@style/ThemeOverlay.MaterialComponents.ActionBar"
        app:title="Group Events"
        app:titleTextColor="@color/on_surface" />

    <TextView
        android:id="@+id/tv_group_events_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:text="Manage your group calendar events."
        android:textColor="@color/on_surface_variant"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/layout_group_events_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_surface_card"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Event"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_group_event_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:hint="Title"
            android:inputType="textCapSentences"
            android:padding="14dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant" />

        <EditText
            android:id="@+id/et_group_event_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:gravity="top"
            android:hint="Description"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:padding="14dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant" />

        <EditText
            android:id="@+id/et_group_event_datetime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:hint="Date/time (e.g. 2026-05-05 14:00)"
            android:inputType="text"
            android:padding="14dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant" />

        <Button
            android:id="@+id/btn_create_group_event"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_primary"
            android:text="Create Group Event"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_group_events"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="26dp" />

    <TextView
        android:id="@+id/tv_group_events_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:paddingHorizontal="20dp"
        android:textAlignment="center"
        android:textColor="@color/on_surface_variant"
        android:textSize="15sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_retry_group_events"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_primary"
        android:text="Retry"
        android:textAllCaps="false"
        android:textColor="@color/on_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <ListView
        android:id="@+id/lv_group_events"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp"
        android:listSelector="@android:color/transparent"
        android:paddingHorizontal="16dp"
        android:scrollbars="none" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_bar"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="18dp">

        <Button
            android:id="@+id/btn_back_from_group_events"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Back To Dashboard"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
