<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_blackjack_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Offline Mode: Blackjack"
        android:textColor="@color/primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_blackjack_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Gameplay UI to be implemented in offline module."
        android:textColor="@color/on_surface_variant" />

</LinearLayout>
