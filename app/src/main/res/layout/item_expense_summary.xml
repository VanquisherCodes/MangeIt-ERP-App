<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_surface_card_low"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tv_expense_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Poster printing"
        android:textColor="@color/on_surface"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_expense_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="EUR 110.00"
        android:textColor="@color/primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_expense_date_vendor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="2026-04-20 • Campus Print Shop"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_expense_notes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Marketing posters"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />
</LinearLayout>
