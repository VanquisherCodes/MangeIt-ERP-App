<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
        </shape>
    </item>

    <item android:gravity="top|start">
        <shape android:shape="oval">
            <size
                android:width="420dp"
                android:height="420dp" />
            <gradient
                android:centerColor="@color/screen_glow_primary_center"
                android:endColor="@color/screen_glow_primary_end"
                android:gradientRadius="220dp"
                android:startColor="@color/screen_glow_primary_start"
                android:type="radial" />
        </shape>
    </item>

    <item
        android:gravity="bottom|end"
        android:right="-80dp"
        android:bottom="-80dp">
        <shape android:shape="oval">
            <size
                android:width="360dp"
                android:height="360dp" />
            <gradient
                android:centerColor="@color/screen_glow_tertiary_center"
                android:endColor="@color/screen_glow_tertiary_end"
                android:gradientRadius="180dp"
                android:startColor="@color/screen_glow_tertiary_start"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
