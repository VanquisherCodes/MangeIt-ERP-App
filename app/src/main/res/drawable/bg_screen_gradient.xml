<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
        </shape>
    </item>

    <item android:gravity="top|start">
        <shape android:shape="oval">
            <size
                android:width="420dp"
                android:height="420dp" />
            <gradient
                android:centerColor="#1A4EDEA3"
                android:endColor="#004EDEA3"
                android:gradientRadius="220dp"
                android:startColor="#334EDEA3"
                android:type="radial" />
        </shape>
    </item>

    <item
        android:gravity="bottom|end"
        android:right="-80dp"
        android:bottom="-80dp">
        <shape android:shape="oval">
            <size
                android:width="360dp"
                android:height="360dp" />
            <gradient
                android:centerColor="#147BD0FF"
                android:endColor="#007BD0FF"
                android:gradientRadius="180dp"
                android:startColor="#247BD0FF"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
